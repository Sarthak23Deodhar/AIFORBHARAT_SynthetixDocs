# .env
# AI-Augmented Technical Navigator for Bharat — AWS Configuration
#
# Rename this file to `.env` and add your Hackathon AWS credentials.
# IMPORTANT: Use us-east-1 — Bedrock (Claude 3.5 Sonnet) and Polly
# neural voices (Aditi, Kajal) are available there.

AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_SESSION_TOKEN="your-session-token-if-using-temporary-credentials"
AWS_REGION="us-east-1"
