# .env
# AI-Augmented Technical Navigator for Bharat — AWS Configuration
#
# Rename this file to `.env` and add your Hackathon AWS credentials.
# IMPORTANT: Use us-east-1 — Bedrock (Claude 3.5 Sonnet) and Polly
# neural voices (Aditi, Kajal) are available there.
# (These are used locally and by the Serverless framework to deploy)
# We rename them so the dotenv plugin doesn't try to push them to Lambda 
# (Lambda uses IAM roles automatically, and these keys are reserved there).

# AWS_SESSION_TOKEN not used for standard IAM user
AWS_REGION="us-east-1"
